{
  "name": "@inflowenger/flow-trace",
  "version": "0.1.0",
  "description": "Parses the Inflow process event stream into flow movement and completion. Dependency-free, framework-agnostic.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "tsc -p tsconfig.test.json && node --test test-dist/test/",
    "typecheck": "tsc -p tsconfig.build.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "typescript": "~6.0.2"
  },
  "keywords": [
    "inflow",
    "workflow",
    "flow",
    "trace",
    "events",
    "logs"
  ],
  "license": "MIT"
}
